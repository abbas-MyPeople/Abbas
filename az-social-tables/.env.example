# az-social-tables — environment template. Copy to .env for local overrides.
# NEVER commit a real .env. Real values live in the deploy platform's dashboard
# (same convention as the sibling Render apps: sync: false).

# Operator console (HTTP Basic auth). Dev default is admin/admin — change
# these before exposing the app anywhere beyond localhost.
AUTH_USER=admin
AUTH_PASS=change-me

# Flask session secret (flash messages). Any long random string.
FLASK_SECRET_KEY=change-me-long-random

# Local port (default 5100)
PORT=5100

# Where the JSON store lives (default: ./data/db.json, gitignored)
# AZST_DB_PATH=/path/to/db.json

# Clover — FUTURE, not used yet. The adapter is mocked; setting mode to
# "real" intentionally raises until the real read-only client is built.
AZST_CLOVER_MODE=mock
# CLOVER_API_TOKEN=   # never commit; read-only token only
# CLOVER_MERCHANT_ID=
